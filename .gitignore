# ═══════════════════════════════════════════════════
# VERIDD — .gitignore
# ═══════════════════════════════════════════════════

# ── Dependencies ──
node_modules/

# ── Environment & Secrets ──
.env
.env.local
.env.development
.env.production
.env.test

# ── Build Outputs ──
dist/
build/
frontend/dist/
frontend/dev/

# ── Smart Contract Artifacts ──
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
contracts/coverage/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ──
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE & Editors ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── TypeScript Build Info ──
*.tsbuildinfo
frontend/nul
frontend/test.html

# ── Coverage Reports ──
coverage/
htmlcov/
.coverage
coverage.xml

# ── Secret Scan Artifacts ──
gitleaks-report.*
.gitleaks-baseline.json
