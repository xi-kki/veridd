# ── Required ──
# Your wallet private key (must have 0G testnet funds)
PRIVATE_KEY=

# ── Optional (recommended) ──
# xAI Grok API key for AI generation. Without this, bot uses basic fallbacks.
GROK_KEY=

# ── Optional (defaults below) ──
# Loop interval in milliseconds (default: 30000 = 30 seconds)
# INTERVAL=30000

# Bot agent name (default: random)
# NAME=Alpha
